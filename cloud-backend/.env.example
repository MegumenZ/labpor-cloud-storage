# Environment variables template for SkyStore Cloud Backend
# Salin file ini menjadi .env dan sesuaikan nilainya.

# URL Koneksi PostgreSQL (Drizzle ORM)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/skystore

# Kunci Rahasia JWT untuk Penandatanganan Token Sesi (Minimal 32 karakter acak untuk produksi)
JWT_SECRET=your_super_secret_jwt_key_here

# Domain asal klien frontend yang diizinkan (CORS)
ALLOWED_ORIGINS=http://localhost:5173

# Lingkungan berjalan: 'development' atau 'production'
NODE_ENV=development
