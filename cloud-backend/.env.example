# Environment variables template for Labpro Storage Cloud Backend
# Salin file ini menjadi .env dan sesuaikan nilainya.

# URL Koneksi PostgreSQL (Drizzle ORM)
DATABASE_URL=postgres://postgres:123456789@localhost:5432/skripsi_cloud

# Kunci Rahasia JWT untuk Penandatanganan Token Sesi (Minimal 32 karakter acak untuk produksi)
JWT_SECRET=your_super_secret_jwt_key_here

# Domain asal klien frontend yang diizinkan (CORS)
ALLOWED_ORIGINS=http://localhost:5173

# Lingkungan berjalan: 'development' atau 'production'
NODE_ENV=development

# Konfigurasi Ceph RGW S3 Storage
S3_ENDPOINT=http://192.168.100.53:8000
S3_ACCESS_KEY_ID=your_s3_access_key
S3_SECRET_ACCESS_KEY=your_s3_secret_key
S3_BUCKET_NAME=labpro-storage
S3_REGION=us-east-1

# Ceph Manager Prometheus metrics url untuk mendeteksi kapasitas penyimpanan total OSD secara dinamis
CEPH_PROM_URL=http://192.168.100.53:9283/metrics
